### 2. RESEND OTP CODE, FOR ACTIVATION ACCOUNT
POST {{host}}/api/v1/auth/resend-verification
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}

{
  "email": "anindita.lestari@example.com"
}

### 3. VERIFY EMAIL OTP, VISIT http://localhost:8025/ (IN DEV MODE) TO GET OTP CODE
POST {{host}}/api/v1/auth/verify-email
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}

{
"email": "anindita.lestari@example.com",
"otp_code": "721471"
}

### 4. LOGIN REQUEST
POST {{host}}/api/v1/auth/login
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}

{
  "email": "maya.kartika.sari@example.com",
  "password": "ValidPass4$"
}


### 5. MFA SETUP
# MASUKAN ACCESS TOKEN DARI RESPONSE LOGIN SEBELUMNYA
@accessToken = eyJhbGciOiJIUzUxMiJ9.eyJyb2xlcyI6WyJDVVNUT01FUiJdLCJ1c2VyQ29kZSI6IlVTUi0yMDI2MDMwMS0wMDAwMiIsInN1YiI6Ijg4MzIxODQ0LWFjMjctNDA3MC1hZTRlLTIxNTkyY2Q1MTMzNCIsImlzcyI6ImF1dGgtc2VydmljZSIsImF1ZCI6WyJiYW5raW5nLWFwaSJdLCJqdGkiOiIyMDZkNWI2Ny0xOWFhLTQyYTMtYmIxYy05YjA3MTBiNjBmYzIiLCJpYXQiOjE3NzIzNzIwMDEsImV4cCI6MTc3MjM3MjkwMX0.Q46TsLjw3igliTUZ9kMrMq83-Ykfy3K9hTPybEWFW1zrhwbNOClHb4hK5shesVbbpWWo44N69kb426T-vA7mpg
POST {{host}}/api/v1/auth/mfa/setup
Content-Type: application/json
X-Correlation-ID: {{correlationId}}
Authorization: Bearer {{accessToken}}


### 6. ENABLE MFA SETUP,
# 1. SCAN QR CODE DARI RESPONSE SEBELUMNYA MENGGUNAKAN APLIKASI AUTHENTICATOR (GOOGLE AUTHENTICATOR, MICROSOFT AUTHENTICATOR, DLL)
# 2. DAPATKAN OTP CODE DARI APLIKASI AUTHENTIC
# 3. KIRIM OTP CODE,
POST {{host}}/api/v1/auth/mfa/setup/verify
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}
Authorization: Bearer {{accessToken}}

{
    "otp_code" : "950064"
}


### 7.  MFA VALIDATE — tukar mfaToken → accessToken + refreshToken
# 1. DAPATKAN MFA TOKEN DARI RESPONSE LOGIN SEBELUMNYA
# 2  OTP COODE DI DAPAT DARI APLIKASI AUTHENTICATOR
@mfaToken = eyJhbGciOiJIUzUxMiJ9.eyJ0eXBlIjoibWZhIiwic3ViIjoiODgzMjE4NDQtYWMyNy00MDcwLWFlNGUtMjE1OTJjZDUxMzM0IiwiaXNzIjoiYXV0aC1zZXJ2aWNlIiwiYXVkIjpbImF1dGgtc2VydmljZSJdLCJqdGkiOiI2MTAwYzBiMC05ZmI3LTQxOWItYmQzYy05YjI2ZDhjMDY4YzYiLCJpYXQiOjE3NzIzNzE5NTEsImV4cCI6MTc3MjM3MjI1MX0.f-mPGW0mp3CffZxV9lYQFCk25vNRK51YAu6DCxkZBM9rSOJaYeSK0UWm967A_cChFbXmpKvHnNZpzANzxZLIfA
POST {{host}}/api/v1/auth/mfa/validate
Content-Type: application/json
Accept: application/json
X-Correlation-ID: {{correlationId}}
Authorization: Bearer {{mfaToken}}

{
  "otp_code": "669991"
}


### 8. REFRESH TOKEN — TO GET NEW ACCESS TOKEN
@refresh_token = eyJhbGciOiJIUzUxMiJ9.eyJyb2xlcyI6WyJDVVNUT01FUiJdLCJ1c2VyQ29kZSI6IlVTUi0yMDI2MDMwMS0wMDAwMiIsInN1YiI6Ijg4MzIxODQ0LWFjMjctNDA3MC1hZTRlLTIxNTkyY2Q1MTMzNCIsImlzcyI6ImF1dGgtc2VydmljZSIsImF1ZCI6WyJiYW5raW5nLWFwaSJdLCJqdGkiOiIzZWM3M2I1Ny03ZTdiLTQ4MjAtYjUyNy0xNTc5MmJhMmNhOTUiLCJpYXQiOjE3NzIzNDQ2NjAsImV4cCI6MTc3MjM0NTU2MH0.5c3mwJNO5dbfUvfdwMb_sformY4GhZZovCj2bWTxg-UME0WV_71_9FW1geF4tkWDn8IM2uoIC-jPXc1ug-43-A
